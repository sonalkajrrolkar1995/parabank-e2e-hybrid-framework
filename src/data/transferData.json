  "boundaryValues": [
    { "amount": "0",       "label": "Zero boundary",        "valid": false },
    { "amount": "0.01",    "label": "Minimum positive",     "valid": true  },
    { "amount": "1.00",    "label": "One dollar",           "valid": true  },
    { "amount": "100.00",  "label": "Standard amount",      "valid": true  },
    { "amount": "-0.01",   "label": "Minimum negative",     "valid": false },
