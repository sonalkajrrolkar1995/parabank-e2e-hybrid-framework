      "category": "boundary"
    },
    {
      "id": "empty_amount",
      "amount": "",
      "description": "No amount entered",
      "expectedSuccess": false,
      "expectedError": "Please enter a valid amount.",
      "category": "invalid"
    },
    {
      "id": "non_numeric_amount",
      "amount": "abc",
      "description": "Non-numeric amount",
      "expectedSuccess": false,
      "expectedError": "Please enter a valid amount.",
      "category": "invalid"
    },
    {
      "id": "excessive_amount",
      "amount": "9999999.99",
      "description": "Amount exceeding available balance",
      "expectedSuccess": false,
      "category": "boundary"
    }
